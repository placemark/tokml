{
	"name": "@placemarkio/tokml",
	"version": "0.3.8",
	"description": "Convert GeoJSON to KML",
	"main": "dist/tokml.cjs",
	"module": "dist/tokml.es.mjs",
	"typings": "dist/index.d.ts",
	"author": "Tom MacWright",
	"license": "MIT",
	"homepage": "https://github.com/placemark/tokml",
	"repository": {
		"url": "https://github.com/placemark/tokml",
		"type": "git"
	},
	"exports": {
		"require": "./dist/tokml.cjs",
		"types": "./dist/index.d.ts",
		"default": "./dist/tokml.es.mjs"
	},
	"keywords": [
		"kml",
		"geojson"
	],
	"publishConfig": {
		"access": "public"
	},
	"husky": {
		"hooks": {
			"pre-commit": "pnpm lint"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"test": "vitest",
		"lint": "biome check",
		"doc": "typedoc --options typedoc.json",
		"prepublish": "rollup -c rollup.config.mjs && cp CNAME docs/CNAME"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@changesets/cli": "^2.30.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@tmcw/togeojson": "7.1.2",
		"@types/geojson": "^7946.0.16",
		"@types/xast": "^2.0.4",
		"rollup": "4.59.0",
		"rollup-plugin-dts": "^6.4.0",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.17",
		"typescript": "^5.9.3",
		"unist-builder": "^4.0.0",
		"vitest": "^4.1.0",
		"xast-util-to-xml": "^4.0.0",
		"xastscript": "^4.0.0"
	}
}
